{
  "name": "ajglobe",
  "version": "0.0.1",
  "description": "Correct, fast orthographic globe rendering for polygons, lines and points — no antimeridian or pole hacks, by construction.",
  "type": "module",
  "main": "./dist/ajglobe.min.js",
  "module": "./dist/ajglobe.min.js",
  "exports": {
    ".": "./dist/ajglobe.min.js",
    "./src/orb.js": "./src/orb.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "serve": "python3 -m http.server 8080",
    "test": "node --test",
    "build": "npm run build:esm && npm run build:iife",
    "build:esm": "esbuild src/orb.js --bundle --format=esm --minify --sourcemap --external:https://* --outfile=dist/ajglobe.min.js",
    "build:iife": "esbuild src/orb.js --bundle --format=iife --global-name=ajglobe --minify --sourcemap --external:https://* --outfile=dist/ajglobe.iife.min.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "globe",
    "orthographic",
    "webgl2",
    "geojson",
    "map",
    "dggs",
    "visualization"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
